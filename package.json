{
  "name": "memory-upgrades-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:pages": "node scripts/verify-site-pages.mjs",
    "doctor": "npx expo-doctor",
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')&&fs.existsSync('.env.example')) fs.copyFileSync('.env.example','.env'); console.log('Copy .env.example to .env if needed, then run: npm run eas:login && npm run eas:init');\"",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "eas:login": "eas-cli login",
    "eas:whoami": "eas-cli whoami",
    "eas:init": "eas-cli init",
    "eas:setup": "node scripts/setup-eas.mjs",
    "build:android": "eas-cli build --platform android --profile production",
    "build:ios": "eas-cli build --platform ios --profile production",
    "build:preview:android": "eas-cli build --platform android --profile preview",
    "build:preview:ios": "eas-cli build --platform ios --profile preview",
    "submit:android": "eas-cli submit --platform android --profile production",
    "submit:ios": "eas-cli submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "expo": "~55.0.26",
    "expo-build-properties": "~55.0.4",
    "expo-linking": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.3.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
