{
  "name": "memory-upgrades-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:pages": "node scripts/verify-site-pages.mjs",
    "doctor": "npx expo-doctor",
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')&&fs.existsSync('.env.example')) fs.copyFileSync('.env.example','.env'); console.log('Copy .env.example to .env if needed, then run: eas login && eas init');\"",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "expo": "~55.0.4",
    "expo-build-properties": "~55.0.4",
    "expo-linking": "~8.0.2",
    "expo-status-bar": "~55.0.4",
    "react-native-safe-area-context": "~5.6.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}